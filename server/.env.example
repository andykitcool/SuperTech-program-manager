# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=supertech_pm

# Runtime: development / production
ENVIRONMENT=development

# JWT
# Leave empty in development to generate an ephemeral local secret.
# Set a strong value in production, for example: openssl rand -base64 48
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Used only before the admin password is changed and stored in DB.
ADMIN_INITIAL_PASSWORD=admin123

# Comma-separated origins. Use concrete origins in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Default Storage Provider: aliyun / tencent / qiniu
DEFAULT_STORAGE_PROVIDER=aliyun

# Aliyun OSS (example, configure in admin UI)
# ALIYUN_OSS_ACCESS_KEY_ID=
# ALIYUN_OSS_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET=
# ALIYUN_OSS_ENDPOINT=
# ALIYUN_OSS_REGION=

# Tencent COS (example)
# TENCENT_COS_SECRET_ID=
# TENCENT_COS_SECRET_KEY=
# TENCENT_COS_BUCKET=
# TENCENT_COS_REGION=

# Qiniu (example)
# QINIU_ACCESS_KEY=
# QINIU_SECRET_KEY=
# QINIU_BUCKET=
# QINIU_DOMAIN=

# Photo Sync
PHOTO_SYNC_INTERVAL_MINUTES=3
PHOTO_SYNC_TIME_TOLERANCE_MINUTES=5

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
